{
  "framework": "vite",
  "installCommand": "cd .. && pnpm install",
  "buildCommand": "cd .. && pnpm --filter shared build && pnpm --filter frontend build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://schoollaiderbackend-production.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
