# ===================
# LOCAL DEVELOPMENT
# ===================

# Database (local Docker)
DATABASE_URL="postgresql://schoollaider:schoollaider_dev@localhost:5432/schoollaider"

# JWT (min 16 characters)
JWT_SECRET="change-me-to-a-random-secret"
JWT_REFRESH_SECRET="change-me-to-another-random-secret"

# MinIO / S3 (local Docker)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin123"
S3_BUCKET="schoollaider-documents"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ===================
# PRODUCTION (Railway)
# ===================
# Set these as environment variables in Railway dashboard:
#
# DATABASE_URL        → Provided by Railway PostgreSQL plugin
# JWT_SECRET          → Generate: openssl rand -base64 32
# JWT_REFRESH_SECRET  → Generate: openssl rand -base64 32
# S3_ENDPOINT         → Your Cloudflare R2 or Supabase Storage URL
# S3_ACCESS_KEY       → Your storage access key
# S3_SECRET_KEY       → Your storage secret key
# S3_BUCKET           → schoollaider-documents
# PORT                → 3001 (or Railway sets this automatically)
# NODE_ENV            → production
# FRONTEND_URL        → https://your-app.vercel.app

# ===================
# PRODUCTION (Vercel Frontend)
# ===================
# Set in Vercel dashboard → Settings → Environment Variables:
#
# VITE_API_URL        → https://your-app.up.railway.app/api
