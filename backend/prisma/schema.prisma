generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BESTUUR_ADMIN
  BESTUUR_GEBRUIKER
  SCHOOL_DIRECTEUR
  SCHOOL_GEBRUIKER
}

enum SchoolStatus {
  ACTIEF
  GEARCHIVEERD
}

enum DocumentType {
  SCHOOLPLAN
  JAARPLAN
  VEILIGHEIDSBELEID
  SCHOOLGIDS
  SOP
  EVALUATIE
  OVERIG
  // Kwaliteitsmodule document types
  PEDAGOGISCH_BELEIDSPLAN
  RESULTATENANALYSE
  IB_JAARVERSLAG
  AUDITRAPPORT
  RIE
  OUDERCOMMISSIE_REGLEMENT
}

enum DocumentStatus {
  ACTUEEL
  VERLOPEN
  CONCEPT
}

enum BewijsStatus {
  AANTOONBAAR
  ONVOLLEDIG
  ONTBREEKT
}

enum PdcaFase {
  PLAN
  DO
  CHECK
  ACT
}

enum PdcaStatus {
  NIET_GESTART
  BEZIG
  AFGEROND
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiSourceType {
  MANUAL
  AI_GENERATED
  AI_ASSISTED
}

enum HrRisico {
  STABIEL
  KWETSBAAR
  HOOG_RISICO
}

enum HrSignaalStatus {
  OPEN
  IN_BEHANDELING
  AFGEHANDELD
}

// ─── Core models ────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  naam      String
  slug      String   @unique
  active    Boolean  @default(true)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schools   School[]
  users     User[]
  documents Document[]

  @@map("tenants")
}

model School {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  naam           String
  brinCode       String       @map("brin_code")
  adres          String
  directeur      String       @default("")
  leerlingaantal Int          @default(0) @map("leerling_aantal")
  status         SchoolStatus @default(ACTIEF)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users             User[]
  documents         Document[]
  standaardStatuses SchoolStandaardStatus[]
  pdcaItems         PdcaItem[]
  readinessScores   ReadinessScore[]
  pdcaSuggestions   PdcaSuggestion[]
  hrFormatie        HrFormatie[]
  hrVerzuim         HrVerzuim[]
  hrVervanging      HrVervanging[]
  hrLeeftijd        HrLeeftijd[]
  hrSignalen        HrSignaal[]

  @@map("schools")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  naam         String
  role         Role     @default(SCHOOL_GEBRUIKER)
  schoolId     String?  @map("school_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  school           School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  documents        Document[]
  documentVersions DocumentVersion[]

  @@map("users")
}

// ─── Document models ────────────────────────────────────────

model Document {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  schoolId     String         @map("school_id")
  titel        String
  beschrijving String
  s3Key        String         @map("s3_key")
  type         DocumentType
  status       DocumentStatus @default(CONCEPT)
  uploadedBy   String         @map("uploaded_by")
  versie       Int            @default(1)
  vervaltDatum DateTime?      @map("vervalt_datum")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  school         School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [uploadedBy], references: [id])
  versions       DocumentVersion[]
  standaardLinks DocumentStandaardLink[]
  analyses       DocumentAnalysis[]

  @@index([tenantId, schoolId, type])
  @@map("documents")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  versie     Int
  s3Key      String   @map("s3_key")
  uploadedBy String   @map("uploaded_by")
  opmerking  String   @default("")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [uploadedBy], references: [id])

  @@map("document_versions")
}

model DocumentStandaardLink {
  id          String @id @default(uuid())
  documentId  String @map("document_id")
  standaardId String @map("standaard_id")

  document  Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  standaard InspectieStandaard @relation(fields: [standaardId], references: [id], onDelete: Cascade)

  @@unique([documentId, standaardId])
  @@map("document_standaard_links")
}

// ─── Inspection framework models ────────────────────────────

model InspectieDomein {
  id           String @id @default(uuid())
  code         String @unique
  naam         String
  beschrijving String
  versie       String

  standaarden InspectieStandaard[]

  @@map("inspectie_domeinen")
}

model InspectieStandaard {
  id           String @id @default(uuid())
  domeinId     String @map("domein_id")
  code         String @unique
  naam         String
  beschrijving String
  toelichting  String @default("")
  gewicht      Int    @default(1)

  domein         InspectieDomein         @relation(fields: [domeinId], references: [id], onDelete: Cascade)
  schoolStatuses SchoolStandaardStatus[]
  documentLinks  DocumentStandaardLink[]
  sectionLinks   SectionStandaardLink[]

  @@map("inspectie_standaarden")
}

model SchoolStandaardStatus {
  id          String       @id @default(uuid())
  schoolId    String       @map("school_id")
  standaardId String       @map("standaard_id")
  status      BewijsStatus @default(ONTBREEKT)
  bewijs      String       @default("")
  evaluatie   String       @default("")
  actueel     Boolean      @default(false)
  opmerking   String       @default("")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  school    School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  standaard InspectieStandaard @relation(fields: [standaardId], references: [id], onDelete: Cascade)

  @@unique([schoolId, standaardId])
  @@map("school_standaard_statuses")
}

// ─── PDCA models ────────────────────────────────────────────

model PdcaItem {
  id             String       @id @default(uuid())
  schoolId       String       @map("school_id")
  schooljaar     String
  fase           PdcaFase
  titel          String
  beschrijving   String       @default("")
  status         PdcaStatus   @default(NIET_GESTART)
  deadline       DateTime?
  bron           AiSourceType @default(MANUAL)
  bronDocumentId String?      @map("bron_document_id")
  vertrouwen     Float?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fromSuggestions PdcaSuggestion[]

  @@index([schoolId, schooljaar])
  @@map("pdca_items")
}

model PdcaSuggestion {
  id             String   @id @default(uuid())
  schoolId       String   @map("school_id")
  schooljaar     String
  fase           PdcaFase
  titel          String
  beschrijving   String   @default("") @db.Text
  bronDocumentId String?  @map("bron_document_id")
  bronSectie     String?  @map("bron_sectie")
  vertrouwen     Float    @default(0)
  status         String   @default("pending") // pending, accepted, dismissed
  pdcaItemId     String?  @map("pdca_item_id")
  createdAt      DateTime @default(now()) @map("created_at")

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pdcaItem PdcaItem? @relation(fields: [pdcaItemId], references: [id], onDelete: SetNull)

  @@index([schoolId, schooljaar, status])
  @@map("pdca_suggestions")
}

// ─── Readiness models ───────────────────────────────────────

model ReadinessScore {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  totalScore   Float    @map("total_score")
  domainScores Json     @map("domain_scores")
  berekendOp   DateTime @default(now()) @map("berekend_op")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("readiness_scores")
}

// ─── AI Analysis models ─────────────────────────────────────

model DocumentAnalysis {
  id              String         @id @default(uuid())
  documentId      String         @map("document_id")
  documentVersion Int            @map("document_version")
  status          AnalysisStatus @default(PENDING)
  extractedText   String?        @map("extracted_text") @db.Text
  sections        Json?
  mappings        Json?
  gaps            Json?
  overlaps        Json?
  summary         String?        @db.Text
  tokenCount      Int?           @map("token_count")
  costCents       Int?           @map("cost_cents")
  errorMessage    String?        @map("error_message") @db.Text
  startedAt       DateTime?      @map("started_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  document        Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentSections DocumentSection[]

  @@unique([documentId, documentVersion])
  @@index([documentId])
  @@map("document_analyses")
}

model DocumentSection {
  id          String   @id @default(uuid())
  analysisId  String   @map("analysis_id")
  titel       String
  inhoud      String   @db.Text
  startPagina Int?     @map("start_pagina")
  eindPagina  Int?     @map("eind_pagina")
  volgorde    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  analysis       DocumentAnalysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  standaardLinks SectionStandaardLink[]

  @@index([analysisId])
  @@map("document_sections")
}

model SectionStandaardLink {
  id          String @id @default(uuid())
  sectionId   String @map("section_id")
  standaardId String @map("standaard_id")
  relevance   Float  @default(0)
  evidence    String @default("") @db.Text

  section   DocumentSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  standaard InspectieStandaard @relation(fields: [standaardId], references: [id], onDelete: Cascade)

  @@unique([sectionId, standaardId])
  @@map("section_standaard_links")
}

model AnalysisJob {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  documentId   String         @map("document_id")
  jobType      String         @default("full_analysis") @map("job_type")
  status       AnalysisStatus @default(PENDING)
  progress     Int            @default(0)
  resultId     String?        @map("result_id")
  errorMessage String?        @map("error_message")
  attempts     Int            @default(0)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@index([documentId])
  @@map("analysis_jobs")
}

// ─── HR Module models ──────────────────────────────────────

model HrFormatie {
  id               String   @id @default(uuid())
  schoolId         String   @map("school_id")
  schooljaar       String
  begroteFte       Float    @map("begrote_fte")
  ingevuldeFte     Float    @map("ingevulde_fte")
  vacatures        Int      @default(0)
  tijdelijkPct     Float    @default(0) @map("tijdelijk_pct")
  fteLeerkracht    Float    @default(0) @map("fte_leerkracht")
  fteOop           Float    @default(0) @map("fte_oop")
  fteDirectie      Float    @default(0) @map("fte_directie")
  capaciteitsScore Float    @default(0) @map("capaciteits_score")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, schooljaar])
  @@index([schoolId])
  @@map("hr_formatie")
}

model HrVerzuim {
  id                     String   @id @default(uuid())
  schoolId               String   @map("school_id")
  periode                String
  verzuimPct             Float    @map("verzuim_pct")
  kortVerzuimPct         Float    @default(0) @map("kort_verzuim_pct")
  langVerzuimPct         Float    @default(0) @map("lang_verzuim_pct")
  ziekteVervangingsDagen Int      @default(0) @map("ziekte_vervangings_dagen")
  belastbaarheidsIndex   Float    @default(0) @map("belastbaarheids_index")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, periode])
  @@index([schoolId])
  @@map("hr_verzuim")
}

model HrVervanging {
  id                     String   @id @default(uuid())
  schoolId               String   @map("school_id")
  schooljaar             String
  totaalVervangingsDagen Int      @map("totaal_vervangings_dagen")
  nietVervuldeDagen      Int      @default(0) @map("niet_vervulde_dagen")
  kostenVervanging       Float    @default(0) @map("kosten_vervanging")
  totaalFte              Float    @default(0) @map("totaal_fte")
  vervangingsIndex       Float    @default(0) @map("vervangings_index")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, schooljaar])
  @@index([schoolId])
  @@map("hr_vervanging")
}

model HrLeeftijd {
  id                      String   @id @default(uuid())
  schoolId                String   @map("school_id")
  schooljaar              String
  categorieOnder30        Int      @default(0) @map("categorie_onder_30")
  categorie30Tot40        Int      @default(0) @map("categorie_30_tot_40")
  categorie40Tot50        Int      @default(0) @map("categorie_40_tot_50")
  categorie50Tot60        Int      @default(0) @map("categorie_50_tot_60")
  categorie60Plus         Int      @default(0) @map("categorie_60_plus")
  verwachteUitstroom3Jaar Float    @default(0) @map("verwachte_uitstroom_3_jaar")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, schooljaar])
  @@index([schoolId])
  @@map("hr_leeftijd")
}

model HrSignaal {
  id              String          @id @default(uuid())
  schoolId        String          @map("school_id")
  type            String
  titel           String
  beschrijving    String          @db.Text
  aanbevolenActie String          @default("") @map("aanbevolen_actie") @db.Text
  deadline        DateTime?
  status          HrSignaalStatus @default(OPEN)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@map("hr_signalen")
}

// ─── Subsidie Module models ───────────────────────────────

enum SubsidieStatus {
  GESIGNALEERD
  ORIENTATIE
  AANVRAAG_IN_VOORBEREIDING
  INGEDIEND
  TOEGEKEND
  LOPEND
  VERANTWOORDING_VEREIST
  VERANTWOORD
  AFGEROND
  AFGEWEZEN
  INGETROKKEN
}

enum BestedingsCategorie {
  PERSONEEL
  MATERIAAL
  EXTERN_DIENSTEN
  ICT
  HUISVESTING
  OVERHEAD
  OVERIG
}

enum SubsidieDocumentType {
  AANVRAAGFORMULIER
  BESCHIKKING
  VOORTGANGSRAPPORTAGE
  EINDVERANTWOORDING
  BIJLAGE
  OVERIG
}

enum SubsidieSignaalType {
  NIEUWE_SUBSIDIE
  DEADLINE_AANVRAAG
  DEADLINE_VERANTWOORDING
  ONDERBESTEDING
  BESCHIKKING_ONTVANGEN
  SUBSIDIE_VERLOPEN
  VERANTWOORDING_ONVOLLEDIG
}

enum SubsidieUrgentie {
  INFO
  WAARSCHUWING
  KRITIEK
}

model SubsidieRegeling {
  id                       String    @id @default(cuid())
  naam                     String
  slug                     String    @unique
  financier                String
  financierUrl             String?   @map("financier_url")
  beschrijving             String    @db.Text
  doelgroep                String
  minBedrag                Float?    @map("min_bedrag")
  maxBedrag                Float?    @map("max_bedrag")
  bedragPerEenheid         String?   @map("bedrag_per_eenheid")
  aanvraagPeriodeOpen      DateTime? @map("aanvraag_periode_open")
  aanvraagPeriodeSluiting  DateTime? @map("aanvraag_periode_sluiting")
  projectPeriodeStart      DateTime? @map("project_periode_start")
  projectPeriodeEinde      DateTime? @map("project_periode_einde")
  verantwoordingDeadline   String?   @map("verantwoording_deadline")
  verantwoordingEisen      String?   @map("verantwoording_eisen") @db.Text
  vereisten                String?   @db.Text
  tags                     String[]
  actief                   Boolean   @default(true)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  dossiers SubsidieDossier[]
  matches  SubsidieMatch[]

  @@map("subsidie_regelingen")
}

model SubsidieMatch {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  subsidieId       String   @map("subsidie_id")
  matchScore       Float    @map("match_score")
  matchToelichting String?  @map("match_toelichting") @db.Text
  gezien           Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  regeling SubsidieRegeling @relation(fields: [subsidieId], references: [id])

  @@unique([tenantId, subsidieId])
  @@index([tenantId])
  @@map("subsidie_matches")
}

model SubsidieDossier {
  id                     String         @id @default(cuid())
  tenantId               String         @map("tenant_id")
  subsidieId             String         @map("subsidie_id")
  naam                   String
  status                 SubsidieStatus @default(GESIGNALEERD)
  bedragAangevraagd      Float?         @map("bedrag_aangevraagd")
  bedragToegekend        Float?         @map("bedrag_toegekend")
  bedragBesteed          Float          @default(0) @map("bedrag_besteed")
  aanvraagDatum          DateTime?      @map("aanvraag_datum")
  beschikkingDatum       DateTime?      @map("beschikking_datum")
  projectStart           DateTime?      @map("project_start")
  projectEinde           DateTime?      @map("project_einde")
  verantwoordingDeadline DateTime?      @map("verantwoording_deadline")
  beschikkingsnummer     String?
  referentie             String?
  schoolIds              String[]       @map("school_ids")
  notities               String?        @db.Text
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  createdBy              String         @map("created_by")

  regeling       SubsidieRegeling         @relation(fields: [subsidieId], references: [id])
  documenten     SubsidieDocument[]
  bestedingen    SubsidieBesteding[]
  signalen       SubsidieSignaal[]
  verantwoording SubsidieVerantwoording?

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("subsidie_dossiers")
}

model SubsidieBesteding {
  id           String              @id @default(cuid())
  dossierId    String              @map("dossier_id")
  schoolId     String?             @map("school_id")
  datum        DateTime
  bedrag       Float
  categorie    BestedingsCategorie
  omschrijving String
  bonRef       String?             @map("bon_ref")
  createdAt    DateTime            @default(now()) @map("created_at")
  createdBy    String              @map("created_by")

  dossier SubsidieDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@index([dossierId])
  @@map("subsidie_bestedingen")
}

model SubsidieDocument {
  id         String               @id @default(cuid())
  dossierId  String               @map("dossier_id")
  type       SubsidieDocumentType
  naam       String
  s3Key      String               @map("s3_key")
  versie     Int                  @default(1)
  uploadedBy String               @map("uploaded_by")
  uploadedAt DateTime             @default(now()) @map("uploaded_at")

  dossier SubsidieDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@map("subsidie_documenten")
}

model SubsidieVerantwoording {
  id             String    @id @default(cuid())
  dossierId      String    @unique @map("dossier_id")
  checklistItems Json      @map("checklist_items")
  voortgangPct   Float     @default(0) @map("voortgang_pct")
  aiConceptTekst String?   @map("ai_concept_tekst") @db.Text
  ingediendOp    DateTime? @map("ingediend_op")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  dossier SubsidieDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  @@map("subsidie_verantwoordingen")
}

model SubsidieSignaal {
  id           String              @id @default(cuid())
  tenantId     String              @map("tenant_id")
  dossierId    String?             @map("dossier_id")
  regelingId   String?             @map("regeling_id")
  type         SubsidieSignaalType
  titel        String
  beschrijving String
  urgentie     SubsidieUrgentie    @default(INFO)
  gelezen      Boolean             @default(false)
  createdAt    DateTime            @default(now()) @map("created_at")

  dossier SubsidieDossier? @relation(fields: [dossierId], references: [id])

  @@index([tenantId, gelezen])
  @@map("subsidie_signalen")
}
